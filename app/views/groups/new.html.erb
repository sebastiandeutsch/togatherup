<section class="mx-auto max-w-3xl px-6 py-10 text-slate-100 lg:px-10">
  <div class="rounded-3xl border border-slate-800 bg-slate-900/70 p-8 shadow-xl shadow-slate-950/50">
    <h1 class="text-3xl font-semibold text-white">Start a new group</h1>
    <p class="mt-1 text-xs text-slate-500">Build a dedicated corner for your crew.</p>
    <div class="mt-6">
      <%= render partial: "form", locals: { group: @group, url: groups_path, submit_label: "Create group", cancel_path: groups_path } %>
    </div>
  </div>
</section>
