<section class="mx-auto max-w-3xl px-6 py-10 text-slate-100 lg:px-10">
  <div class="rounded-3xl border border-slate-800 bg-slate-900/70 p-8 shadow-xl shadow-slate-950/50">
    <h1 class="text-3xl font-semibold text-white">Edit group</h1>
    <p class="mt-1 text-xs text-slate-500">Refresh the details for your people.</p>
    <div class="mt-6">
      <%= render partial: "form", locals: { group: @group, url: group_path(@group), submit_label: "Update group", cancel_path: group_path(@group) } %>
    </div>
  </div>
</section>
