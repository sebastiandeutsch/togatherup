<section class="mx-auto max-w-4xl px-6 py-10 text-slate-100 lg:px-10">
  <header class="flex flex-col gap-2">
    <h1 class="text-3xl font-semibold text-white"><%= @group.name %> • Invitations</h1>
    <p class="text-xs text-slate-500">Share links or emails so your friends can hop in.</p>
  </header>

  <div class="mt-8 grid gap-6 lg:grid-cols-12">
    <div class="lg:col-span-6 space-y-4">
      <div class="rounded-3xl border border-purple-500/30 bg-slate-900/80 p-6 shadow-2xl shadow-purple-500/20">
        <h2 class="text-lg font-semibold text-white">Generate a new invite</h2>
        <p class="mt-1 text-xs text-slate-500">Email is optional — we’ll still create a shareable link.</p>
        <div class="mt-4">
          <%= form_with model: [@group, @invitation], url: group_group_invitations_path(@group), class: "space-y-4" do |form| %>
            <% if @invitation.errors.any? %>
              <div class="rounded-2xl border border-rose-500/40 bg-rose-500/10 p-4 text-sm text-rose-200">
                <p class="font-semibold">We spotted <%= pluralize(@invitation.errors.count, "issue") %>:</p>
                <ul class="mt-2 list-disc space-y-1 pl-5">
                  <% @invitation.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <div class="space-y-2">
              <%= form.label :email, "Send invite to", class: "text-xs font-semibold uppercase tracking-wide text-slate-400" %>
              <%= form.email_field :email, placeholder: "friend@email.com", class: "w-full rounded-2xl border border-slate-700 bg-slate-950/80 px-4 py-3 text-sm text-white focus:border-purple-400 focus:outline-none" %>
            </div>
            <div class="flex justify-end">
              <%= form.submit "Generate", class: "rounded-2xl bg-purple-500 px-5 py-2 text-xs font-semibold uppercase tracking-wide text-white shadow-lg shadow-purple-500/30 transition hover:bg-purple-400" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="lg:col-span-6 space-y-4">
      <div class="rounded-3xl border border-slate-800 bg-slate-900/70 p-6 shadow-xl shadow-slate-950/50">
        <h2 class="text-lg font-semibold text-white">Active invitations</h2>
        <p class="mt-1 text-xs text-slate-500">Links expire automatically after two weeks.</p>
        <div class="mt-4 space-y-3">
          <% if @invitations.any? %>
            <% @invitations.each do |invite| %>
              <article class="space-y-2 rounded-2xl border border-slate-800/60 bg-slate-950/60 p-4 text-xs text-slate-400">
                <div class="flex items-center justify-between">
                  <span class="text-slate-200">Created <%= time_ago_in_words(invite.created_at) %> ago</span>
                  <%= link_to "Revoke", group_group_invitation_path(@group, invite), data: { turbo_method: :delete, turbo_confirm: "Revoke this invitation?" }, class: "text-rose-300 hover:text-rose-200" %>
                </div>
                <% if invite.email.present? %>
                  <p>Sent to <span class="text-slate-200"><%= invite.email %></span></p>
                <% end %>
                <p>Share link:</p>
                <code class="block break-all rounded-xl bg-slate-900/70 px-3 py-2 text-cyan-300"><%= group_invitation_path(invite.token) %></code>
              </article>
            <% end %>
          <% else %>
            <p class="rounded-2xl border border-dashed border-slate-800/60 bg-slate-950/60 p-5 text-sm text-slate-500">No active invites. Generate one on the left.</p>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>
