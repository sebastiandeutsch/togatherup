<section class="mx-auto max-w-6xl px-6 py-10 text-slate-100 lg:px-10">
  <header class="flex flex-col gap-3">
    <h1 class="text-3xl font-semibold text-white">Your circles</h1>
    <p class="text-xs text-slate-500">Create cozy spaces for every vibe and keep them organized.</p>
  </header>

  <div class="mt-8 grid gap-8 lg:grid-cols-12">
    <div class="space-y-6 lg:col-span-7">
      <div class="rounded-3xl border border-slate-800 bg-slate-900/70 p-6 shadow-xl shadow-slate-950/50">
        <div class="flex items-center justify-between">
          <h2 class="text-lg font-semibold text-white">Groups you run</h2>
          <span class="text-xs text-slate-500"><%= pluralize(@owned_groups.size, "group") %></span>
        </div>
        <div class="mt-4 grid gap-4">
          <% if @owned_groups.any? %>
            <% @owned_groups.each do |group| %>
              <article class="flex items-center justify-between rounded-2xl border border-slate-800/60 bg-slate-950/60 px-5 py-4">
                <div>
                  <h3 class="text-sm font-semibold text-white"><%= link_to group.name, group_path(group), class: "hover:text-purple-200" %></h3>
                  <p class="text-xs text-slate-500"><%= truncate(group.description, length: 90) %></p>
                </div>
                <%= link_to heroicon("arrow-top-right-on-square", variant: :outline, options: { class: "h-5 w-5 text-purple-300" }), group_path(group) %>
              </article>
            <% end %>
          <% else %>
            <p class="rounded-2xl border border-dashed border-slate-800/60 bg-slate-950/50 p-5 text-sm text-slate-500">No owned groups yet. Start one using the form.</p>
          <% end %>
        </div>
      </div>

      <div class="rounded-3xl border border-slate-800 bg-slate-900/70 p-6 shadow-xl shadow-slate-950/50">
        <div class="flex items-center justify-between">
          <h2 class="text-lg font-semibold text-white">Groups you joined</h2>
          <span class="text-xs text-slate-500"><%= pluralize(@member_groups.size, "group") %></span>
        </div>
        <div class="mt-4 grid gap-4">
          <% if @member_groups.any? %>
            <% @member_groups.each do |group| %>
              <article class="flex items-center justify-between rounded-2xl border border-slate-800/60 bg-slate-950/60 px-5 py-4">
                <div>
                  <h3 class="text-sm font-semibold text-white"><%= link_to group.name, group_path(group), class: "hover:text-purple-200" %></h3>
                  <p class="text-xs text-slate-500">Hosted by <%= group.owner.name %></p>
                </div>
                <%= link_to heroicon("arrow-right", variant: :outline, options: { class: "h-5 w-5 text-slate-500 hover:text-cyan-300" }), group_path(group) %>
              </article>
            <% end %>
          <% else %>
            <p class="rounded-2xl border border-dashed border-slate-800/60 bg-slate-950/50 p-5 text-sm text-slate-500">When you accept an invite, it will land here.</p>
          <% end %>
        </div>
      </div>
    </div>

    <aside class="lg:col-span-5">
      <div class="rounded-3xl border border-purple-500/30 bg-slate-900/80 p-6 shadow-2xl shadow-purple-500/20">
        <h2 class="text-lg font-semibold text-white">Launch a new group</h2>
        <p class="mt-1 text-xs text-slate-500">Name it, describe the vibe, and invite your people.</p>
        <div class="mt-6">
          <%= form_with model: @group, class: "space-y-4" do |form| %>
            <% if @group.errors.any? %>
              <div class="rounded-2xl border border-rose-500/40 bg-rose-500/10 p-4 text-sm text-rose-200">
                <p class="font-semibold">Fix these:</p>
                <ul class="mt-2 list-disc space-y-1 pl-5">
                  <% @group.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <div class="space-y-2">
              <%= form.label :name, class: "text-xs font-semibold uppercase tracking-wide text-slate-400" %>
              <%= form.text_field :name, class: "w-full rounded-2xl border border-slate-700 bg-slate-950/80 px-4 py-3 text-sm text-white focus:border-purple-400 focus:outline-none" %>
            </div>
            <div class="space-y-2">
              <%= form.label :description, class: "text-xs font-semibold uppercase tracking-wide text-slate-400" %>
              <%= form.text_area :description, rows: 3, class: "w-full rounded-2xl border border-slate-700 bg-slate-950/80 px-4 py-3 text-sm text-white focus:border-purple-400 focus:outline-none" %>
            </div>
            <div class="flex justify-end pt-2">
              <%= form.submit "Create", class: "rounded-2xl bg-purple-500 px-5 py-2 text-xs font-semibold uppercase tracking-wide text-white shadow-lg shadow-purple-500/30 transition hover:bg-purple-400" %>
            </div>
          <% end %>
        </div>
      </div>
    </aside>
  </div>
</section>
