<section class="mx-auto max-w-6xl px-6 py-10 text-slate-100 lg:px-10">
  <header class="flex flex-col gap-4 rounded-3xl border border-slate-800 bg-slate-900/70 p-8 shadow-2xl shadow-slate-950/50 lg:flex-row lg:items-center lg:justify-between">
    <div>
      <p class="text-xs uppercase tracking-widest text-slate-500">Friend group</p>
      <h1 class="mt-2 text-3xl font-semibold text-white"><%= @group.name %></h1>
      <% if @group.description.present? %>
        <p class="mt-2 max-w-2xl text-sm text-slate-300"><%= @group.description %></p>
      <% end %>
      <p class="mt-3 text-xs text-slate-500">Hosted by <%= @group.owner.name %> • <%= pluralize(@memberships.size, "member") %></p>
    </div>
    <div class="flex flex-wrap items-center gap-3">
      <% if @group.owner == current_user %>
        <%= link_to group_group_invitations_path(@group), class: "flex items-center gap-2 rounded-2xl border border-slate-700 px-4 py-2 text-xs font-semibold text-slate-200 transition hover:border-purple-500/40 hover:text-purple-200" do %>
          <%= heroicon "envelope", variant: :outline, options: { class: "h-4 w-4" } %>
          Manage invites
        <% end %>
        <%= link_to "Edit group", edit_group_path(@group), class: "rounded-2xl border border-slate-700 px-4 py-2 text-xs font-semibold text-slate-200 transition hover:border-purple-500/40 hover:text-purple-200" %>
      <% end %>
      <% membership = @memberships.find { |m| m.user == current_user } %>
      <% if membership && membership.user != @group.owner %>
        <%= link_to "Leave group", group_membership_path(@group, membership), data: { turbo_method: :delete, turbo_confirm: "Leave this group?" }, class: "rounded-2xl bg-rose-500/80 px-4 py-2 text-xs font-semibold text-white transition hover:bg-rose-400" %>
      <% end %>
    </div>
  </header>

  <div class="mt-10 grid gap-8 lg:grid-cols-12">
    <section class="space-y-6 lg:col-span-7">
      <div class="rounded-3xl border border-slate-800 bg-slate-900/70 p-6 shadow-xl shadow-slate-950/50">
        <div class="flex items-center justify-between">
          <h2 class="text-lg font-semibold text-white">Suggest a ToGatherUp</h2>
          <p class="text-xs text-slate-500">Traffic-light votes keep plans calm.</p>
        </div>
        <div class="mt-5">
          <%= form_with model: [@group, @event], class: "space-y-5" do |form| %>
            <% if @event.errors.any? %>
              <div class="rounded-2xl border border-rose-500/40 bg-rose-500/10 p-4 text-sm text-rose-200">
                <p class="font-semibold">Please resolve <%= pluralize(@event.errors.count, "issue") %>:</p>
                <ul class="mt-2 list-disc space-y-1 pl-5">
                  <% @event.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <div class="grid gap-4 sm:grid-cols-2">
              <div class="space-y-2">
                <%= form.label :name, class: "text-xs font-semibold uppercase tracking-wide text-slate-400" %>
                <%= form.text_field :name, class: "w-full rounded-2xl border border-slate-700 bg-slate-950/80 px-4 py-3 text-sm text-white focus:border-purple-400 focus:outline-none" %>
              </div>
              <div class="space-y-2">
                <%= form.label :require_everyone, class: "text-xs font-semibold uppercase tracking-wide text-slate-400" %>
                <div class="flex items-center gap-2 rounded-2xl border border-slate-700 bg-slate-950/80 px-4 py-3 text-sm text-slate-200">
                  <%= form.check_box :require_everyone, class: "h-4 w-4 rounded border-slate-700 bg-slate-900 text-purple-500" %>
                  Everyone needs to be there
                </div>
              </div>
              <div class="sm:col-span-2 space-y-2">
                <%= form.label :description, class: "text-xs font-semibold uppercase tracking-wide text-slate-400" %>
                <%= form.text_area :description, rows: 3, class: "w-full rounded-2xl border border-slate-700 bg-slate-950/80 px-4 py-3 text-sm text-white focus:border-purple-400 focus:outline-none" %>
              </div>
              <div class="space-y-2">
                <%= form.label :requires_contribution, class: "text-xs font-semibold uppercase tracking-wide text-slate-400" %>
                <div class="flex items-center gap-2 rounded-2xl border border-slate-700 bg-slate-950/80 px-4 py-3 text-sm text-slate-200">
                  <%= form.check_box :requires_contribution, class: "h-4 w-4 rounded border-slate-700 bg-slate-900 text-cyan-500" %>
                  Bring something along
                </div>
              </div>
            </div>

            <div class="space-y-3">
              <h3 class="text-xs font-semibold uppercase tracking-wide text-slate-400">Time windows</h3>
              <div class="space-y-3">
                <%= form.fields_for :time_suggestions do |time_form| %>
                  <div class="grid items-end gap-3 rounded-2xl border border-slate-800/60 bg-slate-950/60 p-4 sm:grid-cols-2">
                    <div class="space-y-2">
                      <%= time_form.label :starts_at, "Starts", class: "text-xs font-semibold uppercase tracking-wide text-slate-400" %>
                      <%= time_form.datetime_local_field :starts_at, class: "w-full rounded-2xl border border-slate-700 bg-slate-950/80 px-4 py-2 text-sm text-white focus:border-cyan-400 focus:outline-none" %>
                    </div>
                    <div class="space-y-2">
                      <%= time_form.label :ends_at, "Ends", class: "text-xs font-semibold uppercase tracking-wide text-slate-400" %>
                      <%= time_form.datetime_local_field :ends_at, class: "w-full rounded-2xl border border-slate-700 bg-slate-950/80 px-4 py-2 text-sm text-white focus:border-cyan-400 focus:outline-none" %>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>

            <div class="flex justify-end">
              <%= form.submit "Share proposal", class: "rounded-2xl bg-purple-500 px-6 py-2 text-xs font-semibold uppercase tracking-wide text-white shadow-lg shadow-purple-500/30 transition hover:bg-purple-400" %>
            </div>
          <% end %>
        </div>
      </div>

      <div class="space-y-4">
        <div class="flex items-center justify-between">
          <h2 class="text-lg font-semibold text-white">Current plans</h2>
          <%= link_to "View all", group_events_path(@group), class: "text-xs font-semibold text-slate-400 hover:text-purple-200" %>
        </div>
        <% if @events.any? %>
          <div class="space-y-4">
            <% @events.each do |event| %>
              <article class="rounded-3xl border border-slate-800/60 bg-slate-900/70 p-5 shadow-inner shadow-slate-950/40">
                <div class="flex flex-wrap items-center justify-between gap-3">
                  <div>
                    <h3 class="text-lg font-semibold text-white"><%= link_to event.name, group_event_path(@group, event), class: "hover:text-purple-200" %></h3>
                    <p class="text-xs text-slate-500">
                      <% if event.require_everyone? %>
                        Everyone is required
                      <% else %>
                        Attendance flexible
                      <% end %>
                      •
                      <% if event.requires_contribution? %>
                        Bring something along
                      <% else %>
                        No contributions needed
                      <% end %>
                    </p>
                  </div>
                  <% if event.creator == current_user || @group.owner == current_user %>
                    <div class="flex items-center gap-2">
                      <%= link_to edit_group_event_path(@group, event), class: "inline-flex items-center justify-center rounded-2xl border border-slate-700/60 bg-slate-950/60 p-2 text-slate-400 transition hover:border-purple-500/40 hover:text-purple-200" do %>
                      <%= heroicon "pencil-square", variant: :outline, options: { class: "h-5 w-5" } %>
                      <% end %>
                      <%= link_to group_event_path(@group, event), data: { turbo_method: :delete, turbo_confirm: "Delete this event?" }, class: "inline-flex items-center justify-center rounded-2xl border border-rose-500/40 bg-rose-500/10 p-2 text-rose-300 transition hover:bg-rose-400/20" do %>
                      <%= heroicon "trash", variant: :outline, options: { class: "h-5 w-5" } %>
                      <% end %>
                    </div>
                  <% end %>
                </div>
                <% if event.description.present? %>
                  <p class="mt-3 text-sm text-slate-300"><%= event.description %></p>
                <% end %>
                <div class="mt-4 space-y-3">
                  <% event.time_suggestions.each do |suggestion| %>
                    <div class="rounded-2xl border border-slate-800/60 bg-slate-950/60 p-4">
                      <div class="flex flex-wrap items-center justify-between gap-3">
                        <div>
                          <p class="text-sm font-semibold text-white">
                            <%= l(suggestion.starts_at, format: :long) %>
                            –
                            <%= l(suggestion.ends_at, format: :long) %>
                          </p>
                          <% summary = suggestion.vote_summary %>
                          <p class="mt-1 text-xs text-slate-500">
                            <span class="text-emerald-300">● <%= summary["available"] || 0 %> green</span>
                            &nbsp;·&nbsp;
                            <span class="text-amber-300">● <%= summary["tentative"] || 0 %> yellow</span>
                            &nbsp;·&nbsp;
                            <span class="text-rose-300">● <%= summary["unavailable"] || 0 %> red</span>
                          </p>
                        </div>
                        <%= link_to "Vote", group_event_path(@group, event, anchor: "suggestion-#{suggestion.id}"), class: "rounded-full bg-purple-500/20 px-4 py-2 text-xs font-semibold text-purple-200" %>
                      </div>
                    </div>
                  <% end %>
                </div>
              </article>
            <% end %>
          </div>
        <% else %>
          <p class="rounded-3xl border border-dashed border-slate-800/60 bg-slate-900/60 p-6 text-sm text-slate-500">No plans yet. Create one above to get everyone aligned.</p>
        <% end %>
      </div>
    </section>

    <aside class="space-y-6 lg:col-span-5">
      <div class="rounded-3xl border border-slate-800 bg-slate-900/70 p-6 shadow-xl shadow-slate-950/50">
        <h2 class="text-lg font-semibold text-white">Members</h2>
        <div class="mt-4 space-y-3">
          <% @memberships.each do |membership| %>
            <div class="flex items-center gap-3 rounded-2xl border border-slate-800/60 bg-slate-950/60 px-4 py-3">
              <div class="h-10 w-10 overflow-hidden rounded-2xl border border-slate-800/60 bg-slate-900/60">
                <% if membership.user.avatar.attached? %>
                  <%= image_tag membership.user.avatar_variant(size: 80), class: "h-full w-full object-cover" %>
                <% else %>
                  <div class="flex h-full w-full items-center justify-center text-purple-300">
                    <%= heroicon "user", variant: :outline, options: { class: "h-4 w-4" } %>
                  </div>
                <% end %>
              </div>
              <div class="flex-1">
                <p class="text-sm font-semibold text-white"><%= membership.user.name %></p>
                <p class="text-xs text-slate-500"><%= membership.role.capitalize %></p>
              </div>
              <% if @group.owner == current_user && membership.user != current_user %>
                <%= link_to group_membership_path(@group, membership), data: { turbo_method: :delete, turbo_confirm: "Remove #{membership.user.name}?" }, class: "inline-flex items-center justify-center rounded-2xl border border-rose-500/30 bg-rose-500/10 p-2 text-rose-300 transition hover:bg-rose-400/20" do %>
                  <%= heroicon "x-mark", variant: :solid, options: { class: "h-4 w-4" } %>
                <% end %>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>

      <% if @group.owner == current_user %>
        <div class="rounded-3xl border border-purple-500/30 bg-slate-900/80 p-6 shadow-2xl shadow-purple-500/20">
          <h2 class="text-lg font-semibold text-white">Invite people</h2>
          <p class="mt-1 text-xs text-slate-500">Generate a shareable link. Anyone with it can join after signing in.</p>
          <div class="mt-4 space-y-4">
            <%= form_with model: [@group, @invitation], url: group_group_invitations_path(@group), class: "space-y-3" do |form| %>
              <div class="space-y-2">
                <%= form.label :email, "Email (optional)", class: "text-xs font-semibold uppercase tracking-wide text-slate-400" %>
                <%= form.email_field :email, placeholder: "friend@email.com", class: "w-full rounded-2xl border border-slate-700 bg-slate-950/80 px-4 py-3 text-sm text-white focus:border-purple-400 focus:outline-none" %>
              </div>
              <div class="flex justify-end">
                <%= form.submit "Generate invite", class: "rounded-2xl bg-purple-500 px-5 py-2 text-xs font-semibold uppercase tracking-wide text-white shadow-lg shadow-purple-500/30 transition hover:bg-purple-400" %>
              </div>
            <% end %>

            <% if @active_invitations.any? %>
              <div class="space-y-2">
                <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Active links</p>
                <div class="space-y-2">
                  <% @active_invitations.each do |invite| %>
                    <div class="space-y-1 rounded-2xl border border-slate-800/60 bg-slate-950/60 p-3 text-xs text-slate-400">
                      <p class="font-semibold text-slate-200">Invite created <%= time_ago_in_words(invite.created_at) %> ago</p>
                      <p>Share: <code class="break-all text-cyan-300"><%= group_invitation_path(invite.token) %></code></p>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </aside>
  </div>
</section>
