<section class="mx-auto max-w-4xl px-6 py-10 text-slate-100 lg:px-10">
  <div class="rounded-3xl border border-slate-800 bg-slate-900/70 p-8 shadow-xl shadow-slate-950/50">
    <h1 class="text-3xl font-semibold text-white">Edit ToGatherUp</h1>
    <p class="mt-1 text-xs text-slate-500">Adjust timing or details as plans evolve.</p>
    <div class="mt-6">
      <%= render partial: "form", locals: { event: @event, url: group_event_path(@group, @event), submit_label: "Update ToGatherUp", cancel_path: group_event_path(@group, @event) } %>
    </div>
  </div>
</section>
