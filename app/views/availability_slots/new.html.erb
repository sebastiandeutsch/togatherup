<section class="mx-auto max-w-2xl px-6 py-10 text-slate-100 lg:px-10">
  <div class="rounded-3xl border border-slate-800 bg-slate-900/70 p-8 shadow-xl shadow-slate-950/50">
    <h1 class="text-2xl font-semibold text-white">Add a slot</h1>
    <p class="mt-1 text-xs text-slate-500">Let your friends know when to count on you.</p>
    <div class="mt-6">
      <%= render partial: "form", locals: {
        availability_slot: @availability_slot,
        url: availability_slots_path,
        submit_label: "Save slot",
        cancel_path: availability_slots_path
      } %>
    </div>
  </div>
</section>
