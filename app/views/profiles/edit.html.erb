<section class="mx-auto max-w-4xl px-6 py-10 text-slate-100 lg:px-10">
  <div class="rounded-3xl border border-slate-800/80 bg-slate-900/80 p-8 shadow-2xl shadow-slate-950/60">
    <header class="space-y-2">
      <h1 class="text-3xl font-semibold text-white">Update your profile</h1>
      <p class="text-xs text-slate-500">Polish your presence and add a face to your ToGatherUps.</p>
    </header>

    <%= form_with model: @user, url: profile_path, method: :patch, class: "mt-8 space-y-6", multipart: true do |form| %>
      <% if @user.errors.any? %>
        <div class="rounded-2xl border border-rose-500/40 bg-rose-500/10 p-4 text-sm text-rose-200">
          <p class="font-semibold">We found <%= pluralize(@user.errors.count, "issue") %>:</p>
          <ul class="mt-2 list-disc space-y-1 pl-5">
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="grid gap-6 lg:grid-cols-2">
        <div class="space-y-2">
          <%= form.label :name, class: "text-sm font-medium text-slate-200" %>
          <%= form.text_field :name, class: "w-full rounded-2xl border border-slate-700 bg-slate-950/80 px-4 py-3 text-sm text-white shadow-inner shadow-slate-950/60 focus:border-purple-400 focus:outline-none" %>
        </div>
        <div class="space-y-2">
          <%= form.label :bio, class: "text-sm font-medium text-slate-200" %>
          <%= form.text_area :bio, rows: 3, class: "w-full rounded-2xl border border-slate-700 bg-slate-950/80 px-4 py-3 text-sm text-white shadow-inner shadow-slate-950/60 focus:border-purple-400 focus:outline-none" %>
        </div>
      </div>

      <div class="space-y-2">
        <%= form.label :avatar, class: "text-sm font-medium text-slate-200" %>
        <div class="flex items-center gap-4">
          <div class="h-20 w-20 overflow-hidden rounded-2xl border border-slate-700 bg-slate-950/60">
            <% if @user.avatar.attached? %>
              <%= image_tag @user.avatar_variant(size: 160), class: "h-full w-full object-cover" %>
            <% else %>
              <div class="flex h-full w-full items-center justify-center text-purple-300">
              <%= heroicon "user", variant: :outline, options: { class: "h-8 w-8" } %>
              </div>
            <% end %>
          </div>
          <%= form.file_field :avatar, class: "flex-1 text-sm text-slate-300" %>
        </div>
        <% if @user.avatar.attached? %>
          <label class="flex items-center gap-2 text-xs text-slate-400">
            <%= check_box_tag :remove_avatar, "1", false, class: "h-4 w-4 rounded border-slate-700 bg-slate-900 text-purple-500" %>
            Remove current picture
          </label>
        <% end %>
      </div>

      <div class="flex items-center justify-end gap-3 pt-4">
        <%= link_to "Cancel", profile_path, class: "rounded-2xl border border-slate-700 px-4 py-2 text-sm font-semibold text-slate-200 transition hover:border-slate-500" %>
        <%= form.submit "Save changes", class: "rounded-2xl bg-purple-500 px-5 py-2 text-sm font-semibold text-white shadow-lg shadow-purple-500/30 transition hover:bg-purple-400" %>
      </div>
    <% end %>
  </div>
</section>
